---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AXIS Tax & Technology — 現場から、数字を変える。">

  <!-- Navigation -->
  <header style="
    position: sticky; top: 0; z-index: 50;
    background: rgba(13,15,20,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #2d3148;
  ">
    <nav style="
      max-width: 1200px; margin: 0 auto;
      padding: 0 32px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    ">
      <div style="display: flex; align-items: center; gap: 10px;">
        <div style="
          width: 32px; height: 32px;
          background: #f59e0b;
          display: flex; align-items: center; justify-content: center;
        ">
          <span style="
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500; font-size: 14px;
            color: #0d0f14; letter-spacing: -0.05em;
          ">AX</span>
        </div>
        <span style="
          font-family: 'Noto Serif JP', serif;
          font-weight: 700; font-size: 1rem;
          color: #f4f5f8; letter-spacing: 0.05em;
        ">AXIS</span>
      </div>

      <ul style="
        display: flex; gap: 32px; list-style: none;
        margin: 0; padding: 0;
      ">
        {['サービス', 'アプローチ', '実績', '会社概要', 'お問い合わせ'].map(item => (
          <li>
            <a href="#" style="
              font-size: 0.8rem; color: #c8cdd8;
              text-decoration: none; letter-spacing: 0.08em;
            ">{item}</a>
          </li>
        ))}
      </ul>
    </nav>
  </header>

  <!-- Hero -->
  <section style="
    background: #0d0f14;
    min-height: calc(100vh - 64px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    position: relative;
    overflow: hidden;
  ">
    <!-- 背景グリッド（テクニカル感の演出） -->
    <div style="
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(45,49,72,0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(45,49,72,0.4) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    "></div>

    <!-- 左: テキスト -->
    <div style="
      max-width: 560px; margin-left: auto;
      padding: 96px 64px 96px 32px;
      position: relative; z-index: 1;
    ">
      <div style="
        display: inline-flex; align-items: center; gap: 8px;
        margin-bottom: 32px;
      ">
        <div style="width: 24px; height: 1px; background: #f59e0b;"></div>
        <span style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.7rem; color: #f59e0b;
          letter-spacing: 0.15em; text-transform: uppercase;
        ">IT × Tax Consulting</span>
      </div>

      <h1 style="
        font-family: 'Noto Serif JP', serif;
        font-size: clamp(2.4rem, 4vw, 3.4rem);
        font-weight: 900; line-height: 1.15;
        color: #f4f5f8; margin: 0 0 24px;
      ">
        現場から、<br />
        <span style="color: #f59e0b;">数字を変える。</span>
      </h1>

      <p style="
        font-size: 1rem; color: #c8cdd8;
        line-height: 1.8; margin: 0 0 48px;
        max-width: 440px;
      ">
        テクノロジーの力で業務を解剖し、税務と経営の課題に
        根拠のある答えを出す。私たちは「わかった気になる」
        コンサルタントではなく、手を動かす実践家です。
      </p>

      <div style="display: flex; gap: 16px; align-items: center;">
        <a href="#" style="
          display: inline-block;
          background: #f59e0b; color: #0d0f14;
          padding: 14px 32px;
          font-weight: 700; font-size: 0.875rem;
          text-decoration: none; letter-spacing: 0.05em;
        ">無料相談を予約する</a>

        <a href="#" style="
          display: inline-flex; align-items: center; gap: 8px;
          color: #c8cdd8; text-decoration: none;
          font-size: 0.875rem; letter-spacing: 0.05em;
        ">
          <span>事例を見る</span>
          <span>→</span>
        </a>
      </div>
    </div>

    <!-- 右: 成果指標パネル（泥臭い業務感 × データ） -->
    <div style="
      padding: 96px 32px 96px 64px;
      position: relative; z-index: 1;
    ">
      <div style="
        border: 1px solid #2d3148;
        background: #161820;
        padding: 40px;
        max-width: 440px;
      ">
        <!-- ターミナル風ヘッダー -->
        <div style="
          display: flex; align-items: center; gap: 8px;
          margin-bottom: 32px;
          padding-bottom: 16px;
          border-bottom: 1px solid #2d3148;
        ">
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444;"></div>
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #f59e0b;"></div>
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #22c55e;"></div>
          <span style="
            margin-left: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem; color: #6b7280;
          ">診断レポート / FY2024Q4</span>
        </div>

        <!-- メトリクス -->
        {[
          { label: '月次決算 リードタイム', before: '15営業日', after: '3営業日', delta: '-80%' },
          { label: '経費精算 工数', before: '40h/月', after: '6h/月', delta: '-85%' },
          { label: '税務リスク検知', before: '年1回', after: 'リアルタイム', delta: '↑↑' },
        ].map(({ label, before, after, delta }) => (
          <div style="margin-bottom: 24px;">
            <div style="
              font-family: 'JetBrains Mono', monospace;
              font-size: 0.65rem; color: #6b7280;
              letter-spacing: 0.1em; margin-bottom: 8px;
            ">$ {label}</div>
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="
                font-size: 0.875rem; color: #6b7280;
                text-decoration: line-through;
              ">{before}</span>
              <span style="color: #6b7280; font-size: 0.75rem;">→</span>
              <span style="
                font-size: 1rem; font-weight: 700; color: #f4f5f8;
              ">{after}</span>
              <span style="
                font-family: 'JetBrains Mono', monospace;
                font-size: 0.75rem; color: #f59e0b;
                margin-left: auto;
              ">{delta}</span>
            </div>
          </div>
        ))}

        <div style="
          margin-top: 8px;
          padding-top: 24px;
          border-top: 1px solid #2d3148;
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.65rem; color: #3d4260;
        ">// 実際のクライアント導入実績より</div>
      </div>
    </div>
  </section>

  <!-- Section: アプローチ -->
  <section style="background: #f4f5f8; padding: 96px 32px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
        <div style="width: 40px; height: 1px; background: #f59e0b;"></div>
        <span style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.7rem; color: #f59e0b;
          letter-spacing: 0.15em; text-transform: uppercase;
        ">Our Approach</span>
      </div>

      <h2 style="
        font-family: 'Noto Serif JP', serif;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        font-weight: 900; color: #0d0f14;
        margin: 0 0 64px; max-width: 600px; line-height: 1.3;
      ">
        ロジックと泥臭さ、<br />どちらも手放さない。
      </h2>

      <div style="
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 2px; background: #c8cdd8;
      ">
        {[
          {
            number: '01',
            title: '業務の解剖',
            body: '現場に入り込み、実際の業務フローを分解する。システムログ・帳票・人の動き、すべてがデータ。「なんとなく」では動かない。',
            tag: 'Process Mining',
          },
          {
            number: '02',
            title: '数字の根拠化',
            body: '税務・財務の判断を感覚ではなくデータで裏付ける。リスクの定量化、節税機会の発見。根拠のない提言はしない。',
            tag: 'Data-Driven Tax',
          },
          {
            number: '03',
            title: '定着まで伴走',
            body: '導入して終わりではない。現場が使いこなせるまでハンズオンで支援する。ツールは手段。目的は業務の変革。',
            tag: 'Implementation',
          },
        ].map(({ number, title, body, tag }) => (
          <div style="background: #f4f5f8; padding: 48px 40px;">
            <div style="
              font-family: 'JetBrains Mono', monospace;
              font-size: 0.7rem; color: #f59e0b;
              letter-spacing: 0.1em; margin-bottom: 24px;
            ">{number}</div>
            <h3 style="
              font-family: 'Noto Serif JP', serif;
              font-size: 1.25rem; font-weight: 700;
              color: #0d0f14; margin: 0 0 16px;
            ">{title}</h3>
            <p style="
              font-size: 0.875rem; color: #3d4260;
              line-height: 1.8; margin: 0 0 32px;
            ">{body}</p>
            <div style="
              display: inline-block;
              border: 1px solid #c8cdd8;
              padding: 4px 12px;
              font-family: 'JetBrains Mono', monospace;
              font-size: 0.65rem; color: #6b7280;
              letter-spacing: 0.08em;
            ">{tag}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section: サービス -->
  <section style="background: #161820; padding: 96px 32px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
        <div style="width: 40px; height: 1px; background: #f59e0b;"></div>
        <span style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.7rem; color: #f59e0b;
          letter-spacing: 0.15em;
        ">Services</span>
      </div>

      <h2 style="
        font-family: 'Noto Serif JP', serif;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        font-weight: 900; color: #f4f5f8;
        margin: 0 0 64px;
      ">提供サービス</h2>

      <div style="
        display: grid; grid-template-columns: repeat(2, 1fr);
        gap: 1px; background: #2d3148;
      ">
        {[
          {
            title: '税務顧問 + テック統合',
            desc: '月次・年次の税務対応に加え、会計SaaSの選定・設定・自動化まで一気通貫で対応。税理士とエンジニアの知見を同時に活用できる。',
            badge: '顧問契約',
          },
          {
            title: '業務効率化コンサルティング',
            desc: '経理・バックオフィスの業務フローを分析し、RPA・API連携・ノーコードツールで工数を削減。費用対効果を数値で提示する。',
            badge: 'プロジェクト',
          },
          {
            title: '税務デューデリジェンス',
            desc: 'M&A・資金調達に伴う税務リスクの精査。財務データを機械的に解析し、見落としがちなリスクポイントを体系的に洗い出す。',
            badge: 'スポット',
          },
          {
            title: '経営管理体制の構築',
            desc: 'KPI設計からダッシュボード構築まで。経営判断に必要な数字をリアルタイムで可視化する仕組みを、現場に合わせてゼロから設計する。',
            badge: 'プロジェクト',
          },
        ].map(({ title, desc, badge }) => (
          <div style="
            background: #161820; padding: 48px 40px;
            position: relative;
          ">
            <div style="
              display: inline-block;
              background: #0d0f14; border: 1px solid #2d3148;
              padding: 3px 10px;
              font-family: 'JetBrains Mono', monospace;
              font-size: 0.65rem; color: #6b7280;
              margin-bottom: 24px;
            ">{badge}</div>
            <h3 style="
              font-family: 'Noto Serif JP', serif;
              font-size: 1.25rem; font-weight: 700;
              color: #f4f5f8; margin: 0 0 16px;
            ">{title}</h3>
            <p style="
              font-size: 0.875rem; color: #6b7280;
              line-height: 1.8; margin: 0;
            ">{desc}</p>
            <div style="
              position: absolute; bottom: 40px; right: 40px;
              color: #3d4260; font-size: 1.2rem;
            ">→</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section: 実績数字 -->
  <section style="background: #f59e0b; padding: 80px 32px;">
    <div style="
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr);
    ">
      {[
        { value: '127', unit: '社', label: '支援実績' },
        { value: '4.2', unit: '億円', label: '削減した税負担（累計）' },
        { value: '83', unit: '%', label: '業務工数削減 平均値' },
        { value: '11', unit: '年', label: '業界経験年数' },
      ].map(({ value, unit, label }) => (
        <div style="
          padding: 48px 40px;
          border-right: 1px solid rgba(0,0,0,0.15);
        ">
          <div style="display: flex; align-items: baseline; gap: 4px; margin-bottom: 8px;">
            <span style="
              font-family: 'Noto Serif JP', serif;
              font-size: 3rem; font-weight: 900;
              color: #0d0f14; line-height: 1;
            ">{value}</span>
            <span style="font-size: 1rem; font-weight: 700; color: #0d0f14;">{unit}</span>
          </div>
          <div style="font-size: 0.8rem; color: #92400e; letter-spacing: 0.05em;">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section style="
    background: #0d0f14;
    padding: 120px 32px; text-align: center;
  ">
    <div style="max-width: 640px; margin: 0 auto;">
      <div style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem; color: #f59e0b;
        letter-spacing: 0.15em; margin-bottom: 24px;
      ">// まずは現状を聞かせてください</div>
      <h2 style="
        font-family: 'Noto Serif JP', serif;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 900; color: #f4f5f8;
        margin: 0 0 24px; line-height: 1.3;
      ">
        数字の課題に、<br />根拠のある答えを。
      </h2>
      <p style="
        font-size: 0.9rem; color: #6b7280;
        line-height: 1.8; margin: 0 0 48px;
      ">
        初回相談は無料です。現在の業務・税務・システムの状況を<br />
        整理するだけでも、発見があるはずです。
      </p>
      <a href="#" style="
        display: inline-block;
        background: #f59e0b; color: #0d0f14;
        padding: 18px 48px;
        font-weight: 700; font-size: 1rem;
        text-decoration: none; letter-spacing: 0.05em;
      ">無料相談を予約する →</a>
    </div>
  </section>

  <!-- Footer -->
  <footer style="
    background: #161820;
    border-top: 1px solid #2d3148;
    padding: 48px 32px;
  ">
    <div style="
      max-width: 1200px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
    ">
      <div style="display: flex; align-items: center; gap: 10px;">
        <div style="
          width: 24px; height: 24px; background: #f59e0b;
          display: flex; align-items: center; justify-content: center;
        ">
          <span style="
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500; font-size: 10px; color: #0d0f14;
          ">AX</span>
        </div>
        <span style="
          font-family: 'Noto Serif JP', serif;
          font-size: 0.875rem; color: #6b7280;
        ">AXIS Tax & Technology</span>
      </div>
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem; color: #3d4260;
      ">© 2024 AXIS. All rights reserved.</span>
    </div>
  </footer>

</Layout>
