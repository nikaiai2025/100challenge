# Local-only environment variables for 20260311
# Copy to .env (do not commit) and fill values.

GEMINI_API_KEY=your_api_key_here

# Optional: used by server scripts
FILE_SEARCH_STORE=aozora-100-store
FILE_SEARCH_STORE_ID=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_UPLOAD_BASE=https://generativelanguage.googleapis.com/upload/v1beta
AOZORA_PREPROCESSED_DIR=./Aozora_Texts_Preprocessed
UPLOAD_DELAY_MS=1200
LOCAL_PROXY_PORT=8787
FIXED_DB_PATH=./doc_id_map.jsonl
UPLOAD_RETRY_MAX=3
UPLOAD_RETRY_BASE_MS=1000
UPLOAD_LIMIT=0
UPLOAD_OFFSET=0
UPLOAD_TEST_FILE=
